{
  "name": "cloud-bottom-leds",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Simulate LED-strip lighting patterns behind a bumpy, diffuse cloud surface and stream them live to real WLED strips.",
  "scripts": {
