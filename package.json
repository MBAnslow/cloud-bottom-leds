    "preview": "vite preview",
    "server": "node server/index.mjs",
    "start": "npm run server"
  },
  "dependencies": {
    "express": "^4.19.2",
    "lil-gui": "^0.19.2",
    "three": "^0.165.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/three": "^0.165.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
